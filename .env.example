# Binance Testnet API credentials (Get them from https://testnet.binance.vision/)
BINANCE_API_KEY=your_binance_testnet_api_key_here
BINANCE_API_SECRET=your_binance_testnet_api_secret_here

# Safety Configuration: Set to True to only simulate trades locally (highly recommended for testing)
# Set to False to place live orders on the Binance SPOT Testnet using testnet funds.
DISABLE_ORDER_EXECUTION=True

# Initial portfolio value for local paper trading if Testnet API is not used or disabled
INITIAL_USDT_BALANCE=10000.0

# Dashboard settings
DASHBOARD_PORT=5001
DASHBOARD_HOST=0.0.0.0

# Paths
DB_PATH=trading_system.db
MODEL_PATH=xgboost_model.json
